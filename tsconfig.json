{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": ["ES2022"],
        "strict": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "isolatedModules": true,
        "types": [
            "jest",
            "node"
        ],
        "noEmit": true
    },
    "include": [
        "src/**/*",
        "src/data/*.json",
        "tests/**/*"
    ]
}
